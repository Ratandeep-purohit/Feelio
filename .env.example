# ═══════════════════════════════════════════════════════
#  Feelio — Environment Variables Template
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your actual values in .env
#  3. NEVER commit your .env to Git
# ═══════════════════════════════════════════════════════

# Database connection string
# Format: mysql+pymysql://USERNAME:PASSWORD@HOST/DATABASE_NAME
# URL-encode special chars in password (@ becomes %40, # becomes %23)
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost/emotion_buddy

# Flask session secret (use a long random string in production)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Debug mode (True for development, False for production)
FLASK_DEBUG=True
