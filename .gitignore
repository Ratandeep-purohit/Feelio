# ═══════════════════════════════════════════════
#  Feelio — .gitignore
# ═══════════════════════════════════════════════

# ── SECRETS (NEVER commit these) ────────────────
.env
*.env
.env.*
!.env.example

# ── Python ──────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# ── Virtual Environments ─────────────────────────
venv/
env/
.venv/
.env_local/
ENV/

# ── IDEs & Editors ───────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Flask / App ──────────────────────────────────
instance/
.webassets-cache
flask_session/

# ── Testing ──────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Logs ─────────────────────────────────────────
*.log
logs/
